# Copy to .env and fill in values

DATABASE_URL=mysql://user:pass@localhost:3306/flowdesk
REDIS_URL=redis://127.0.0.1:6379
PORT=4000

# Public URL of the frontend (used in assignment emails)
APP_URL=http://localhost:3000

# Outgoing email (task assigned, etc.). If SMTP_HOST is unset, emails are skipped.
# Examples: Mailgun, SendGrid SMTP, Amazon SES, or Gmail with an App Password.
SMTP_HOST= smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=false
SMTP_USER= app.flowdesk@gmail.com
SMTP_PASS= cpnexismjfmzemkd
SMTP_FROM="FlowDesk <app.flowdesk@gmail.com>"
